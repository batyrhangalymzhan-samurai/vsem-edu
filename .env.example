# Скопируйте этот файл в .env (для локальной разработки через `vercel dev`)
# и/или задайте те же переменные в Vercel → Project Settings → Environment Variables.

# GitHub-репозиторий, из которого Vercel деплоит сайт
GITHUB_OWNER=ваш-github-логин
GITHUB_REPO=vsem-edu-main
GITHUB_BRANCH=main

# Personal Access Token с правом "repo" (Contents: Read and write)
# GitHub → Settings → Developer settings → Personal access tokens → Fine-grained tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Пароль для входа в /admin
ADMIN_PASSWORD=придумайте-надёжный-пароль

# Случайная строка для подписи сессионных токенов админки (любой набор символов)
SESSION_SECRET=придумайте-случайную-строку
